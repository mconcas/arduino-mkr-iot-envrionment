{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Carrier Status",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "index": 0, "text": "DOWN", "color": "red" },
                "1": { "index": 1, "text": "UP",   "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mkr_iot_carrier_up",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Temperature (HTS221)",
      "description": "Environmental temperature from the HTS221 humidity/temperature sensor.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "celsius",
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "green",  "value": 10 },
              { "color": "#EAB839", "value": 30 },
              { "color": "red",    "value": 40 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mkr_iot_carrier_temperature_celsius{sensor=\"hts221\"}",
          "legendFormat": "HTS221",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pressure",
      "description": "Atmospheric pressure from the LPS22HB barometric sensor.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "pressurekpa",
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "green",  "value": 90 },
              { "color": "yellow", "value": 103 },
              { "color": "orange", "value": 110 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mkr_iot_carrier_pressure_kilopascals",
          "legendFormat": "Pressure",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Illuminance",
      "description": "Light level derived from the APDS9960 RGB sensor using Avago application-note coefficients.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "lux",
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#1F60C4", "value": null },
              { "color": "#EAB839", "value": 10 },
              { "color": "green",   "value": 100 },
              { "color": "super-light-green", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mkr_iot_carrier_illuminance_lux",
          "legendFormat": "Illuminance",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Soil Moisture",
      "description": "Resistive soil moisture sensor on pin A5. NaN when sensor is absent (floating pin detected).",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 0,
          "min": 0,
          "max": 100,
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "nan",
                "result": { "text": "No sensor", "color": "text", "index": 0 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 20 },
              { "color": "green",  "value": 40 },
              { "color": "#5794F2", "value": 75 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mkr_iot_carrier_soil_moisture_percent",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Wi-Fi Signal",
      "description": "RSSI from the WiFiNINA module. Closer to 0 dBm is stronger.",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "dBm",
          "decimals": 0,
          "min": -100,
          "max": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": -80 },
              { "color": "#EAB839","value": -70 },
              { "color": "green",  "value": -55 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mkr_iot_carrier_wifi_rssi_dbm",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Temperature",
      "description": "Both on-carrier temperature sensors. HTS221 measures ambient humidity+temperature; LPS22HB is the barometric sensor which runs slightly warmer due to self-heating.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "°C",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "celsius",
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "min", "max", "mean"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mkr_iot_carrier_temperature_celsius",
          "legendFormat": "{{sensor}}",
          "refId": "A"
        }
      ]
    },
